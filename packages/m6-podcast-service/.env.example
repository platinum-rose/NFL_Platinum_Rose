# Service identity
NODE_ENV=production
PORT=5060
HOST=127.0.0.1

# HMAC shared secret for /ingest/* endpoints (cron trigger)
# Generate with: openssl rand -hex 32
NFL_PODCAST_HMAC_SECRET=

# Supabase service role (writes to podcast_*, vault_notes, share_*)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloud-fallback extraction (used only when local quality gate fails)
OPENAI_API_KEY=

# Local Ollama (for primary extraction, Phase 4)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# Storage roots on M6 (Phase 3+)
NFL_AUDIO_DIR=/var/lib/nfl/audio
NFL_TRANSCRIPT_DIR=/var/lib/nfl/transcripts
NFL_DIGEST_DIR=/var/lib/nfl/digest

# Phase 4 wiring: where the Python venv + extractor module live on M6.
NFL_PYTHON_EXECUTABLE=/home/andrewlrose/projects/NFL_Dashboard/packages/m6-podcast-service/python/.venv/bin/python
NFL_PYTHON_CWD=/home/andrewlrose/projects/NFL_Dashboard/packages/m6-podcast-service/python
