{
  "name": "nfl-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:test": "vite build --mode test",
    "lint": "eslint .",
    "preview": "vite preview",
    "update-schedule": "node scripts/update-schedule.js",
    "ingest-schedule": "node agents/schedule-ingest.js --year 2026 --season-type 2 --start-week 1 --end-week 18",
    "ingest-schedule:full": "node agents/schedule-ingest.js --year 2026 --season-type 2 --start-week 1 --end-week 18 --include-playoffs",
    "ingest-futures": "node agents/futures-odds-ingest.js --season 2026",
    "ingest-futures:dry": "node agents/futures-odds-ingest.js --season 2026 --dry-run",
    "ingest-research-intel": "node agents/research-intel-ingest.js",
    "ingest-research-intel:dry": "node agents/research-intel-ingest.js --dry-run",
    "test:smoke": "playwright test",
    "resume": "node scripts/gen_resume.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "overnight": "node scripts/overnight.js",
    "daily-brief": "node agents/nfl-daily-brief.js",
    "daily-brief:dry": "node agents/nfl-daily-brief.js --dry-run",
    "seed:vault": "node agents/vault-seed.js",
    "seed:vault:dry": "node agents/vault-seed.js --dry-run",
    "seed:vault:dvoa": "node agents/vault-seed.js --dir dvoa",
    "seed:vault:ats": "node agents/vault-seed.js --dir ats",
    "seed:vault:splits": "node agents/vault-seed.js --dir splits",
    "seed:vault:manual": "node agents/vault-seed.js --dir manual",
    "ingest-tweets": "node agents/tweet-ingest.js",
    "ingest-tweets:dry": "node agents/tweet-ingest.js --dry-run",
    "fetch:nflverse": "python scripts/fetch_nflverse_data.py",
    "fetch:nflverse:dry": "python scripts/fetch_nflverse_data.py --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.562.0",
    "nodemailer": "^8.0.8",
    "node-fetch": "^3.3.2",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.4",
    "vitest": "^4.1.5"
  }
}
